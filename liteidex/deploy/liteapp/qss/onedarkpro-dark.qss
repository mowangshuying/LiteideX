/* === One Dark Pro Dark Theme (QSS) === */
/* Based on One Dark Pro for VSCode */

/* === Shared === */
QMainWindow{
    background-color: #282C34;
    color: #ABB2BF;
}

QStackedWidget, QLabel, QPushButton, QRadioButton, QCheckBox, 
QGroupBox, QStatusBar, QToolButton, QComboBox, QDialog, QListView,
QTabBar, QMenu, QMenuBar, QWidget::window, QWidget  {
    background-color: #282C34;
    color: #ABB2BF;
}

/* === QWidget === */
QWidget:window {
}

/* === WebView === */
QTextBrowser, QWebView {
    background-color: #FAFAFA;
    selection-color: white; 
    selection-background-color: #3E4451;
}

/* === QToolTip === */
QToolTip {
    background-color: #21252B;
    border: 1px solid #3E4451;
    color: #ABB2BF;
}

/* === QPushButton === */
QPushButton {
    border: 1px solid #3E4451;
    padding: 3px 12px;
    background-color: #2C313A;
    margin: 0 1px;
}

QPushButton:hover {
    background-color: #3E4451;
    border-color: #61AFEF;
}

QPushButton:pressed {
    background-color: #61AFEF;
    border-color: #61AFEF;
    color: #282C34;
}

QPushButton:disabled {
    color: #5C6370;
}

/* === Checkable items === */
QCheckBox::indicator, QRadioButton::indicator, QTreeView::indicator {
    width: 12px;
    height: 12px;
    background-color: #2C313A;
    border: 1px solid #3E4451;
}


QRadioButton::indicator {
    border-radius: 2px;
}

QRadioButton::indicator::checked {
    background-color: qradialgradient(cx:0.5, cy:0.5, fx:0.5, fy:0.5, radius:1.0, stop:0.25 #61AFEF, stop:0.3 #2C313A);
}


QCheckBox::indicator::checked {
	image: url("../share/liteide/liteapp/qrc/default/liteapp/images/checkmarkdark.png");
}

QTreeView::indicator::checked {
	image: url("../share/liteide/liteapp/qrc/default/liteapp/images/checkmarkdark.png");
}



QRadioButton::indicator:disabled {
    background-color: #5C6370;
}

QCheckBox::indicator::disabled {
	background-color: #5C6370;
}

QTreeView::indicator:disabled {
    background-color: #5C6370;
}


QRadioButton::indicator::checked:disabled{
    background-color: qradialgradient(cx:0.5, cy:0.5, fx:0.25, fy:0.15, radius:0.3, stop:0 #BBBBBB, stop:1 #444444);
}

QCheckBox::indicator::checked:disabled {
	background-color: #5C6370;
	image: url("../share/liteide/liteapp/qrc/default/liteapp/images/checkmarkdark.png");
}


QTreeView::indicator::checked:disabled {
    background-color: #5C6370;
	image: url("../share/liteide/liteapp/qrc/default/liteapp/images/checkmarkdark.png");
}

/* === QComboBox === */
QComboBox {
    background-color: #2C313A;
    border: 1px solid #3E4451;
    color: #ABB2BF;
    padding: 2px 9px;
}

QComboBox:hover {
    background-color: #3E4451;
    border: 1px solid #61AFEF;
}

QComboBox::drop-down {
    background-color: #2C313A;
    subcontrol-origin: padding;
    subcontrol-position: top right;
    border-left: 1px solid #3E4451;
}

QComboBox::drop-down:hover {
    background-color: #3E4451;
    border-left: 1px solid #61AFEF;
}

QComboBox::down-arrow {
    border: 1px solid transparent;
	width: 8px;
    height: 8px;
    background: #2C313A;
	image: url("../share/liteide/liteapp/qrc/default/liteapp/images/chevrondowndark.png");
}

QComboBox::down-arrow:hover {
    border: 1px solid transparent;
    background: #3E4451;
}

QComboBox QAbstractItemView {
    background-color: #21252B;
    border: 1px solid #3E4451;
    selection-background-color: #3E4451;
    outline: 0;
}

QComboBox QAbstractItemView::item {
    min-height: 18px;
    padding: 3px 6px;
    color: #ABB2BF;
}

QComboBox QAbstractItemView::item:hover {
    background-color: #3E4451;
}

QComboBox QAbstractItemView::item:selected {
    background-color: #61AFEF;
    color: #282C34;
}

/* === QGroupBox === */
QGroupBox {
    border: 1px solid #3E4451;
    margin-top: 6px;
}

QGroupBox::title {
    color: #61AFEF;
    subcontrol-origin: margin;
    subcontrol-position: top left;
    margin-left: 2px;
}

/* === QTabWidget === */
QTabWidget::pane {
    background: #282C34;
    border: 1px solid #3E4451;
    color: #ABB2BF;
}

/* === QTabBar === */
QTabBar::tab {
    background: #282C34;
    border: 1px solid transparent;
    color: #ABB2BF;
    min-width: 30px;
    padding: 3px 12px
}

QTabBar::tab:hover {
    background-color: #61AFEF;
    border-bottom: none;
}

QTabBar::tab:selected {
    background-color: #61AFEF;
    border: 1px solid #3E4451;
    border-top: none;
    border-top: 1px solid #3E4451;
    border-bottom: 0px solid #3E4451;
    color: #282C34;
}

/* === QToolBar === */
QToolBar {
    background-color: #282C34;
    border: none;
    padding: 1px;
    min-height: 18px;
}

QToolBar:handle {
    background: transparent;
    border-left: 1px solid #3E4451;
}

QToolBar::separator {
    width: 3px;
    background-color: transparent;
}

/* === QToolButton === */
QToolButton {
    background-color: #282C34; 
    border: none;
    margin: 1px;
    padding: 2px;
    min-width: 12px;
    min-height: 12px;
}

QToolButton:hover {
    background-color: #3E4451;
    border: 1px solid #3E4451;
}

QToolButton[popupMode="1"] {
    padding-right: 10px;
}
QToolButton[popupMode="2"] {
    padding-right: 5px;
    background-color: #3E4451; 
}
QToolButton[popupMode="2"]:hover {
    background-color: #2C313A; 
}

QToolButton::menu-button {
    border-left: 1px solid #3E4451;
    background: #2C313A;
}

QToolButton::menu-button:hover {
    border-left: 1px solid #61AFEF;
    background: #3E4451;
}

QToolButton:pressed {
    background-color: #61AFEF;
    color: #282C34;
}

QToolButton:checked {
    border: 1px solid transparent;
    background-color: transparent;
    color: #61AFEF;
}

RotationToolButton, RotationToolButton:pressed, RotationToolButton:hover, RotationToolButton:checked {
    border-top-width: 3px;
    border-top-style: solid;
    border-top-color: transparent;
    background-color: transparent;
    color: #ABB2BF;
}
RotationToolButton:pressed {
    color: #ABB2BF;
}
RotationToolButton:hover,RotationToolButton:checked:hover {
    background-color: #61AFEF;
    border-top-color: #61AFEF;
}
RotationToolButton:checked  {
    border: 1px solid #61AFEF;
    background-color: #61AFEF;
    color: #282C34;
}


/* === QMenu === */
QMenu {
    background-color: #21252B;
    border: 1px solid #21252B;
    color: #ABB2BF;
    padding: 1px;
}

QMenu::item {
    padding: 1px 21px 2px 21px;
    border: 1px solid transparent;
}

QMenu::item:disabled {
    color: #5C6370;
}

QMenu::item:selected {
    border-color: #3E4451;
    background: #3E4451;
}
QMenu::item:checked {
}

QMenu::icon:checked {
    background: #ABB2BF;
}

QMenu::separator {
    height: 1px;
    background: #2C313A;
    margin: 1px 5px;
}

QMenu::indicator {
    width: 7px;
    height: 7px;
}

/* === QMenuBar === */
QMenuBar {
    background-color: #282C34;
    color: #ABB2BF;
}

QMenuBar::item {
    background: transparent;
}

QMenuBar::item:disabled {
    color: gray;
}

QMenuBar::item:selected {
    background: #3E4451;
}

QMenuBar::item:pressed {
    background: #21252B;
}
 
/* === QScrollBar:vertical === */
QScrollBar:vertical {
    background: #2C313A;
    width: 12px;
    margin: 12px 0 12px 0;
}

QScrollBar::handle:vertical {
    background: #5C6370;
    min-height: 12px;
    border: 1px solid #2C313A;
}

QScrollBar::handle:vertical:hover {
    background: #61AFEF;
    border: 1px solid #2C313A;
}

QScrollBar::add-line:vertical {
    background: #2C313A;
    height: 12px;
    subcontrol-position: bottom;
    subcontrol-origin: margin;
}

QScrollBar::sub-line:vertical {
    background: #2C313A;
    height: 12px;
    subcontrol-position: top;
    subcontrol-origin: margin;
}

QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: #2C313A;
}

QScrollBar:up-arrow:vertical {
    border: 1px solid #2C313A;
    width: 12px;
    height: 12px;
    background: #2C313A;
	image: url("../share/liteide/liteapp/qrc/default/liteapp/images/chevronupdark.png");
}

QScrollBar:down-arrow:vertical {
    border: 1px solid #2C313A;
    width: 12px;
    height: 12px;
    background: #2C313A;
	image: url("../share/liteide/liteapp/qrc/default/liteapp/images/chevrondowndark.png");
}

/* === QScrollBar:horizontal === */
QScrollBar:horizontal {
    background: #2C313A;
    height: 12px;
    margin: 0 12px 0 12px;
}

QScrollBar::handle:horizontal {
    background: #5C6370;
    min-width: 12px;
    border: 1px solid #2C313A;
}

QScrollBar::handle:horizontal:hover {
    background: #61AFEF;
    border: 1px solid #2C313A;
}

QScrollBar::add-line:horizontal {
    background: #2C313A;
    width: 12px;
    subcontrol-position: right;
    subcontrol-origin: margin;
}

QScrollBar::sub-line:horizontal {
    background: #2C313A;
    width: 12px;
    subcontrol-position: left;
    subcontrol-origin: margin;
}

QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal {
    background: #2C313A;
}

QScrollBar:left-arrow:horizontal {
    border: 1px solid #2C313A;
    width: 12px;
    height: 12px;
    background: #2C313A;
	image: url("../share/liteide/liteapp/qrc/default/liteapp/images/chevronleftdark.png");
}

QScrollBar:right-arrow:horizontal {
    border: 1px solid #2C313A;
    width: 12px;
    height: 12px;
    background: #2C313A;
	image: url("../share/liteide/liteapp/qrc/default/liteapp/images/chevronrightdark.png");
}

/* =================== */
QLineEdit, QListView, QTreeView, QTableView, QAbstractSpinBox {
    background-color: #282C34;
    color: #ABB2BF;
    border: 1px solid #3E4451;
}

QAbstractScrollArea, QLineEdit, QTextEdit, QAbstractSpinBox {
    border-color: #3E4451;
    border: 1px solid #3E4451;
}

/* === QHeaderView ===*/
QHeaderView {
    background: #282C34;
} 
QHeaderView::section {
    background: #282C34;
    border: 0;
    color: #ABB2BF;
    padding: 2px 0 2px 2px;
}

/* === QListView === */
QListView::item:hover {
    background: #3E4451;
}

QListView::item:selected {
    background: #282C34;
    color: #61AFEF;
}

/* === QTableView === */
QTableView::item:hover {
    background: #3E4451;
}

QTableView::item:hover {
    background: #282C34;
    color: #61AFEF;
}

/* === QTreeView === */
QTreeView::item {
    background: #282C34;
}

QTreeView::item:hover {
    background: #3E4451;
}

QTreeView::item:selected {
    background: #282C34;
    color: #61AFEF;
}

QTreeView::branch {

}

QTreeView::branch:closed:has-children {
	image: url("../share/liteide/liteapp/qrc/default/liteapp/images/chevronrightdark.png");
}

QTreeView::branch:open:has-children {
	image: url("../share/liteide/liteapp/qrc/default/liteapp/images/chevrondowndark.png");
}

/* === Customizations === */
QFrame#infoLabel {
    border: 1px inset #3E4451;
}

QTextBrowser {
    background-color: #282C34;
    color: #ABB2BF;
}