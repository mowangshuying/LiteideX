/* === One Dark Pro White Theme (QSS) === */
/* Based on One Dark Pro Light for VSCode */

/* === Shared === */
QMainWindow{
    background-color: #FAFAFA;
    color: #383A42;
}

QStackedWidget, QLabel, QPushButton, QRadioButton, QCheckBox, 
QGroupBox, QStatusBar, QToolButton, QComboBox, QDialog, QListView,
QTabBar, QMenu, QMenuBar, QWidget::window, QWidget  {
    background-color: #FAFAFA;
    color: #383A42;
}

/* === QWidget === */
QWidget:window {
}

/* === WebView === */
QTextBrowser, QWebView {
    background-color: #FFFFFF;
    selection-color: white; 
    selection-background-color: #D0D0D0;
}

/* === QToolTip === */
QToolTip {
    background-color: #FFFFFF;
    border: 1px solid #D0D0D0;
    color: #383A42;
}

/* === QPushButton === */
QPushButton {
    border: 1px solid #D0D0D0;
    padding: 3px 12px;
    background-color: #E5E5E5;
    margin: 0 1px;
}

QPushButton:hover {
    background-color: #E8E8E8;
    border-color: #4078F2;
}

QPushButton:pressed {
    background-color: #4078F2;
    border-color: #4078F2;
    color: #FFFFFF;
}

QPushButton:disabled {
    color: #A0A1A7;
}

/* === Checkable items === */
QCheckBox::indicator, QRadioButton::indicator, QTreeView::indicator {
    width: 12px;
    height: 12px;
    background-color: #E5E5E5;
    border: 1px solid #D0D0D0;
}


QRadioButton::indicator {
    border-radius: 2px;
}

QRadioButton::indicator::checked {
    background-color: qradialgradient(cx:0.5, cy:0.5, fx:0.5, fy:0.5, radius:1.0, stop:0.25 #4078F2, stop:0.3 #E5E5E5);
}


QCheckBox::indicator::checked {
	image: url("../share/liteide/liteapp/qrc/default/liteapp/images/checkmark.png");
}

QTreeView::indicator::checked {
	image: url("../share/liteide/liteapp/qrc/default/liteapp/images/checkmark.png");
}



QRadioButton::indicator:disabled {
    background-color: #A0A1A7;
}

QCheckBox::indicator::disabled {
	background-color: #A0A1A7;
}

QTreeView::indicator:disabled {
    background-color: #A0A1A7;
}


QRadioButton::indicator::checked:disabled{
    background-color: qradialgradient(cx:0.5, cy:0.5, fx:0.25, fy:0.15, radius:0.3, stop:0 #BBBBBB, stop:1 #444444);
}

QCheckBox::indicator::checked:disabled {
	background-color: #A0A1A7;
	image: url("../share/liteide/liteapp/qrc/default/liteapp/images/checkmark.png");
}


QTreeView::indicator::checked:disabled {
    background-color: #A0A1A7;
	image: url("../share/liteide/liteapp/qrc/default/liteapp/images/checkmark.png");
}

/* === QComboBox === */
QComboBox {
    background-color: #E5E5E5;
    border: 1px solid #D0D0D0;
    color: #383A42;
    padding: 2px 9px;
}

QComboBox:hover {
    background-color: #E8E8E8;
    border: 1px solid #4078F2;
}

QComboBox::drop-down {
    background-color: #E5E5E5;
    subcontrol-origin: padding;
    subcontrol-position: top right;
    border-left: 1px solid #D0D0D0;
}

QComboBox::drop-down:hover {
    background-color: #E8E8E8;
    border-left: 1px solid #4078F2;
}

QComboBox::down-arrow {
    border: 1px solid transparent;
	width: 8px;
    height: 8px;
    background: #E5E5E5;
	image: url("../share/liteide/liteapp/qrc/default/liteapp/images/chevrondown.png");
}

QComboBox::down-arrow:hover {
    border: 1px solid transparent;
    background: #E8E8E8;
}

QComboBox QAbstractItemView {
    background-color: #FFFFFF;
    border: 1px solid #D0D0D0;
    selection-background-color: #E8E8E8;
    outline: 0;
}

QComboBox QAbstractItemView::item {
    min-height: 18px;
    padding: 3px 6px;
    color: #383A42;
}

QComboBox QAbstractItemView::item:hover {
    background-color: #E8E8E8;
}

QComboBox QAbstractItemView::item:selected {
    background-color: #4078F2;
    color: #FFFFFF;
}

/* === QGroupBox === */
QGroupBox {
    border: 1px solid #D0D0D0;
    margin-top: 6px;
}

QGroupBox::title {
    color: #4078F2;
    subcontrol-origin: margin;
    subcontrol-position: top left;
    margin-left: 2px;
}

/* === QTabWidget === */
QTabWidget::pane {
    background: #FAFAFA;
    border: 1px solid #D0D0D0;
    color: #383A42;
}

/* === QTabBar === */
QTabBar::tab {
    background: #FAFAFA;
    border: 1px solid transparent;
    color: #383A42;
    min-width: 30px;
    padding: 3px 12px
}

QTabBar::tab:hover {
    background-color: #4078F2;
    border-bottom: none;
}

QTabBar::tab:selected {
    background-color: #4078F2;
    border: 1px solid #D0D0D0;
    border-top: none;
    border-top: 1px solid #D0D0D0;
    border-bottom: 0px solid #D0D0D0;
    color: #FFFFFF;
}

/* === QToolBar === */
QToolBar {
    background-color: #FAFAFA;
    border: none;
    padding: 1px;
    min-height: 18px;
}

QToolBar:handle {
    background: transparent;
    border-left: 1px solid #D0D0D0;
}

QToolBar::separator {
    width: 3px;
    background-color: transparent;
}

/* === QToolButton === */
QToolButton {
    background-color: #FAFAFA; 
    border: none;
    margin: 1px;
    padding: 2px;
    min-width: 12px;
    min-height: 12px;
}

QToolButton:hover {
    background-color: #E8E8E8;
    border: 1px solid #E8E8E8;
}

QToolButton[popupMode="1"] {
    padding-right: 10px;
}
QToolButton[popupMode="2"] {
    padding-right: 5px;
}
QToolButton[popupMode="2"]:hover {
}

QToolButton:pressed {
    background-color: #4078F2;
    color: #FFFFFF;
}

QToolButton:checked {
    border: 1px solid transparent;
    background-color: transparent;
    color: #4078F2;
}

RotationToolButton, RotationToolButton:pressed, RotationToolButton:hover, RotationToolButton:checked {
    border-top-width: 3px;
    border-top-style: solid;
    border-top-color: transparent;
    background-color: transparent;
    color: #383A42;
}
RotationToolButton:pressed {
    color: #383A42;
}
RotationToolButton:hover,RotationToolButton:checked:hover {
    background-color: #4078F2;
    border-top-color: #4078F2;
}
RotationToolButton:checked  {
    border: 1px solid #4078F2;
    background-color: #4078F2;
    color: #FFFFFF;
}


/* === QMenu === */
QMenu {
    background-color: #FFFFFF;
    border: 1px solid #D0D0D0;
    color: #383A42;
    padding: 1px;
}

QMenu::item {
    padding: 1px 21px 2px 21px;
    border: 1px solid transparent;
}

QMenu::item:disabled {
    color: #A0A1A7;
}

QMenu::item:selected {
    border-color: #E8E8E8;
    background: #E8E8E8;
}
QMenu::item:checked {
}

QMenu::icon:checked {
    background: #FFFFFF;
}

QMenu::separator {
    height: 1px;
    background: #F0F0F0;
    margin: 1px 5px;
}

QMenu::indicator {
    width: 7px;
    height: 7px;
}

/* === QMenuBar === */
QMenuBar {
    background-color: #FAFAFA;
    color: #383A42;
}

QMenuBar::item {
    background: transparent;
}

QMenuBar::item:disabled {
    color: gray;
}

QMenuBar::item:selected {
    background: #E8E8E8;
}

QMenuBar::item:pressed {
    background: #FFFFFF;
}
 
/* === QScrollBar:vertical === */
QScrollBar:vertical {
    background: #E5E5E5;
    width: 12px;
    margin: 12px 0 12px 0;
}

QScrollBar::handle:vertical {
    background: #A0A1A7;
    min-height: 12px;
    border: 1px solid #E5E5E5;
}

QScrollBar::handle:vertical:hover {
    background: #4078F2;
    border: 1px solid #E5E5E5;
}

QScrollBar::add-line:vertical {
    background: #E5E5E5;
    height: 12px;
    subcontrol-position: bottom;
    subcontrol-origin: margin;
}

QScrollBar::sub-line:vertical {
    background: #E5E5E5;
    height: 12px;
    subcontrol-position: top;
    subcontrol-origin: margin;
}

QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: #E5E5E5;
}

QScrollBar:up-arrow:vertical {
    border: 1px solid #E5E5E5;
    width: 12px;
    height: 12px;
    background: #E5E5E5;
	image: url("../share/liteide/liteapp/qrc/default/liteapp/images/chevronup.png");
}

QScrollBar:down-arrow:vertical {
    border: 1px solid #E5E5E5;
    width: 12px;
    height: 12px;
    background: #E5E5E5;
	image: url("../share/liteide/liteapp/qrc/default/liteapp/images/chevrondown.png");
}

/* === QScrollBar:horizontal === */
QScrollBar:horizontal {
    background: #E5E5E5;
    height: 12px;
    margin: 0 12px 0 12px;
}

QScrollBar::handle:horizontal {
    background: #A0A1A7;
    min-width: 12px;
    border: 1px solid #E5E5E5;
}

QScrollBar::handle:horizontal:hover {
    background: #4078F2;
    border: 1px solid #E5E5E5;
}

QScrollBar::add-line:horizontal {
    background: #E5E5E5;
    width: 12px;
    subcontrol-position: right;
    subcontrol-origin: margin;
}

QScrollBar::sub-line:horizontal {
    background: #E5E5E5;
    width: 12px;
    subcontrol-position: left;
    subcontrol-origin: margin;
}

QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal {
    background: #E5E5E5;
}

QScrollBar:left-arrow:horizontal {
    border: 1px solid #E5E5E5;
    width: 12px;
    height: 12px;
    background: #E5E5E5;
	image: url("../share/liteide/liteapp/qrc/default/liteapp/images/chevronleft.png");
}

QScrollBar:right-arrow:horizontal {
    border: 1px solid #E5E5E5;
    width: 12px;
    height: 12px;
    background: #E5E5E5;
	image: url("../share/liteide/liteapp/qrc/default/liteapp/images/chevronright.png");
}

/* =================== */
QLineEdit, QListView, QTreeView, QTableView, QAbstractSpinBox {
    background-color: #FAFAFA;
    color: #383A42;
    border: 1px solid #D0D0D0;
}

QAbstractScrollArea, QLineEdit, QTextEdit, QAbstractSpinBox {
    border-color: #D0D0D0;
    border: 1px solid #D0D0D0;
}

/* === QHeaderView ===*/
QHeaderView {
    background: #FAFAFA;
} 
QHeaderView::section {
    background: #FAFAFA;
    border: 0;
    color: #383A42;
    padding: 2px 0 2px 2px;
}

/* === QListView === */
QListView::item:hover {
    background: #E8E8E8;
}

QListView::item:selected {
    background: #FAFAFA;
    color: #4078F2;
}

/* === QTableView === */
QTableView::item:hover {
    background: #E8E8E8;
}

QTableView::item:hover {
    background: #FAFAFA;
    color: #4078F2;
}

/* === QTreeView === */
QTreeView::item {
    background: #FAFAFA;
}

QTreeView::item:hover {
    background: #E8E8E8;
}

QTreeView::item:selected {
    background: #FAFAFA;
    color: #4078F2;
}

QTreeView::branch {

}

QTreeView::branch:closed:has-children {
	image: url("../share/liteide/liteapp/qrc/default/liteapp/images/chevronright.png");
}

QTreeView::branch:open:has-children {
	image: url("../share/liteide/liteapp/qrc/default/liteapp/images/chevrondown.png");
}

/* === Customizations === */
QFrame#infoLabel {
    border: 1px inset #D0D0D0;
}

QTextBrowser {
    background-color: #FAFAFA;
    color: #383A42;
}