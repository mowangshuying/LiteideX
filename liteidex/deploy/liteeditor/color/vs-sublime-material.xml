<?xml version="1.0" encoding="UTF-8"?>
<style-scheme version="1.0" name="VS Sublime Material">
  <!--
  VS Sublime Material Theme - Combining Sublime Text Monokai with Material Design
  Classic Sublime colors on Material Dark background
  -->
  
  <!-- 基础文本 - Material Dark 深蓝灰背景，Sublime 风格文字 -->
  <style name="Text" foreground="#EEFFFF" background="#263238"/>
  
  <!-- 额外信息（如行号等）- 与编辑器背景协调的蓝灰色 -->
  <style name="Extra" foreground="#546E7A" background="#263238"/>
  
  <!-- 选中文本 - Material 蓝灰色 -->
  <style name="Selection" background="#37474F"/>
  
  <!-- 当前行高亮 - 稍亮的深蓝灰 -->
  <style name="CurrentLine" background="#2C393F"/>
  
  <!-- 括号匹配 - 中蓝灰 -->
  <style name="MatchBrackets" background="#37474F"/>
  
  <!-- 缩进线 - 暗蓝灰，低调 -->
  <style name="IndentLine" foreground="#2A363B"/>
  
  <!-- 空白字符可视化 - 暗蓝灰点 -->
  <style name="VisualWhitespace" foreground="#37474F"/>
  
  <!-- 关键字 - Sublime Monokai 粉红色 -->
  <style name="Keyword" foreground="#FF79C6" bold="false"/>
  
  <!-- 数据类型 - Sublime Monokai 黄色 -->
  <style name="DataType" foreground="#F1FA8C"/>
  
  <!-- 十进制数字 - Sublime Monokai 紫色 -->
  <style name="Decimal" foreground="#BD93F9"/>
  
  <!-- 基础数字 -->
  <style name="BaseN" foreground="#BD93F9"/>
  
  <!-- 浮点数 -->
  <style name="Float" foreground="#BD93F9"/>
  
  <!-- 字符常量 - Sublime Monokai 绿色 -->
  <style name="Char" foreground="#50FA7B"/>
  
  <!-- 字符串 - Sublime Monokai 绿色 -->
  <style name="String" foreground="#50FA7B"/>
  
  <!-- 注释 - Sublime Monokai 灰绿色 -->
  <style name="Comment" foreground="#6272A4"/>
  
  <!-- 警告/提示 - Sublime Monokai 橙色 -->
  <style name="Alert" foreground="#FFB86C"/>
  
  <!-- 错误 - Sublime Monokai 红色 -->
  <style name="Error" foreground="#FF5555"/>
  
  <!-- 函数调用 - Sublime Monokai 绿色 -->
  <style name="Function" foreground="#50FA7B"/>
  
  <!-- 区域标记 -->
  <style name="RegionMarker" foreground="#EEFFFF"/>
  
  <!-- 符号（运算符等）- Material 青色 -->
  <style name="Symbol" foreground="#80CBC4"/>
  
  <!-- 内置函数 - Sublime Monokai 绿色 -->
  <style name="BuiltinFunc" foreground="#50FA7B"/>
  
  <!-- 预声明标识符 - Sublime Monokai 绿色 -->
  <style name="Predeclared" foreground="#50FA7B"/>
  
  <!-- 函数声明 - Sublime Monokai 绿色 -->
  <style name="FuncDecl" foreground="#50FA7B"/>
  
  <!-- 占位符 -->
  <style name="Placeholder" foreground="#50FA7B"/>
  
  <!-- TODO 注释 - 橙色文字，深色背景 -->
  <style name="ToDo" foreground="#FFB86C" background="#263238" bold="true"/>
</style-scheme>